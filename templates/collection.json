{"sections":{"banner":{"type":"main-collection-banner","settings":{"show_collection_description":true,"show_collection_image":false,"color_scheme":"scheme-1"}},"rich_text_rrnVHi":{"type":"rich-text","blocks":{"text_XTMqFW":{"type":"text","settings":{"text":"<p><strong>Alle modularen Ameisennester sowie Zubehörteile dieser Kollektion werden sorgfältig in <\/strong><span style=\"text-decoration:underline\"><strong>Handarbeit gefertigt<\/strong><\/span><strong>.<\/strong><\/p><p>Jedes Element entsteht im 3D-Druckverfahren und wird anschließend <strong>einzeln geprüft und montiert<\/strong>. Dadurch erhältst du keine Massenware, sondern <span style=\"text-decoration:underline\"><strong>individuell gefertigte Module<\/strong><\/span> mit hoher Passgenauigkeit, Funktionalität und besonderem Augenmerk auf Detail und Qualität. Die nester werden in<strong> Spanien gefertigt<\/strong>.<\/p>"}}},"block_order":["text_XTMqFW"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"scheme-daea1a35-756d-4277-9978-f353bed0ea22","full_width":true,"padding_top":40,"padding_bottom":40}},"product-grid":{"type":"main-collection-product-grid","settings":{"products_per_page":36,"columns_desktop":4,"columns_mobile":"2","color_scheme":"scheme-1","image_ratio":"adapt","image_shape":"default","show_secondary_image":false,"show_vendor":false,"show_rating":false,"quick_add":"standard","enable_filtering":true,"filter_type":"horizontal","enable_sorting":true,"padding_top":36,"padding_bottom":36}}},"order":["banner","rich_text_rrnVHi","product-grid"]}